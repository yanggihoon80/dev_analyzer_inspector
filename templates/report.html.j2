<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <title>Dev Analyzer Inspector 분석 리포트</title>
  <style>
    body { font-family: Inter, Arial, sans-serif; margin: 24px; background: #f4f5f7; color: #1f2937; }
    h1, h2, h3 { color: #111827; margin-top: 0; }
    .tabs { display: flex; gap: 10px; margin: 24px 0 16px; }
    .tab-button { display: inline-flex; align-items: center; justify-content: center; padding: 10px 16px; border: 1px solid #d1d5db; border-radius: 999px; background: #ffffff; color: #374151; font-weight: 700; cursor: pointer; }
    .tab-button.active { background: #111827; color: #ffffff; border-color: #111827; }
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }
    .subtabs { display: flex; gap: 10px; margin: 24px 0 16px; flex-wrap: wrap; }
    .subtab-button { display: inline-flex; align-items: center; justify-content: center; padding: 8px 14px; border: 1px solid #d1d5db; border-radius: 999px; background: #ffffff; color: #374151; font-weight: 700; cursor: pointer; }
    .subtab-button.active { color: #ffffff; }
    .subtab-button.subtab-passed { border-color: #86efac; background: #dcfce7; color: #166534; }
    .subtab-button.subtab-passed.active { background: #22c55e; border-color: #22c55e; }
    .subtab-button.subtab-failed { border-color: #fecaca; background: #fee2e2; color: #991b1b; }
    .subtab-button.subtab-failed.active { background: #ef4444; border-color: #ef4444; }
    .subtab-button.subtab-skipped { border-color: #fde68a; background: #fef3c7; color: #92400e; }
    .subtab-button.subtab-skipped.active { background: #f59e0b; border-color: #f59e0b; }
    .subtab-panel { display: none; }
    .subtab-panel.active { display: block; }
    .page-header { margin-bottom: 24px; }
    .grid { display: grid; gap: 16px; }
    .overview-grid { grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
    .card { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 16px; padding: 20px; box-shadow: 0 1px 2px rgba(15,23,42,0.08); }
    .card h2 { font-size: 1.1rem; margin-bottom: 12px; }
    .stat { font-size: 2rem; font-weight: 700; margin: 0; }
    .stat-label { color: #6b7280; margin-top: 8px; }
    .badge { display: inline-flex; align-items: center; justify-content: center; padding: 4px 10px; border-radius: 999px; font-size: 0.85rem; font-weight: 600; }
    .badge-block { display: flex; width: fit-content; margin: 0 0 8px 0; }
    .badge-high { background: #fee2e2; color: #991b1b; }
    .badge-medium { background: #fef3c7; color: #92400e; }
    .badge-low { background: #d1fae5; color: #166534; }
    .table { width: 100%; border-collapse: collapse; margin-top: 16px; }
    .table th, .table td { border: 1px solid #e5e7eb; padding: 12px; text-align: left; vertical-align: top; word-wrap: break-word; overflow-wrap: anywhere; }
    .table th { background: #f9fafb; font-weight: 700; }
    .col-tool { width: 140px; min-width: 140px; }
    .col-severity { width: 120px; min-width: 120px; }
    .col-affected-files { width: 130px; min-width: 130px; }
    .col-count { width: 80px; min-width: 80px; }
    .col-index { width: 70px; min-width: 70px; }
    .col-line { width: 90px; min-width: 90px; }
    .section-title { margin-top: 40px; margin-bottom: 16px; }
    .code-block { background: #0f172a; color: #e2e8f0; padding: 14px; border-radius: 10px; font-family: ui-monospace, SFMono-Regular, Consolas, "Liberation Mono", Menlo, monospace; white-space: pre-wrap; word-break: break-word; border: 1px solid #cbd5e1; }
    .metadata { color: #6b7280; font-size: 0.95rem; margin-top: 6px; word-wrap: break-word; overflow-wrap: anywhere; }
    .fix-suggestion { margin-top: 18px; padding: 16px; background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 12px; color: #1f2937; }
    .fix-suggestion h4 { margin: 0 0 10px; font-size: 1rem; color: #111827; }
    .fix-suggestion p { margin: 0 0 10px; line-height: 1.6; color: #334155; }
    .fix-suggestion strong { color: #111827; }
    .fix-suggestion-code { margin-top: 8px; }
    .accordion-details { border: 1px solid #e5e7eb; border-radius: 14px; background: #ffffff; overflow: hidden; }
      .accordion-details summary { list-style: none; cursor: pointer; padding: 14px 16px; display: grid; grid-template-columns: minmax(0, 1fr) auto; column-gap: 12px; row-gap: 8px; align-items: start; background: #f8fafc; border-radius: 14px; color: #111827; font-weight: 600; }
    .accordion-details summary::-webkit-details-marker { display: none; }
    .accordion-details summary span { display: inline-flex; align-items: center; gap: 8px; }
    .accordion-content { padding: 0 16px 16px; }
    .accordion-content .code-block { margin-top: 12px; }
    .accordion-details[open] summary { background: #e2e8f0; }
    .summary-list { list-style: none; padding: 0; margin: 0; }
    .summary-list li { margin-bottom: 6px; }
    .ai-summary-card { overflow: hidden; }
    .ai-summary-content, .ai-summary-content > div, .ai-summary-content > section { width: 100%; max-width: 100%; box-sizing: border-box; }
    .ai-summary-content p { margin: 0 0 10px; line-height: 1.7; }
    .ai-summary-content ul, .ai-summary-content ol { margin: 0 0 10px 20px; }
    .ai-summary-content table { width: 100%; max-width: 100%; border-collapse: collapse; table-layout: fixed; margin-top: 12px; display: table; }
    .ai-summary-content th, .ai-summary-content td { border: 1px solid #e5e7eb; padding: 10px; text-align: left; vertical-align: top; word-break: break-word; overflow-wrap: anywhere; }
    .ai-summary-content th { background: #f8fafc; }
    .ai-summary-content tbody, .ai-summary-content thead, .ai-summary-content tr { width: 100%; }
    .ai-summary-content span, .ai-summary-content strong, .ai-summary-content em { max-width: 100%; }
    .ai-summary-fallback { color: #7f1d1d; }
    .api-ai-summary-card .ai-summary-content { max-height: 260px; overflow: auto; padding-right: 4px; font-size: 0.95rem; line-height: 1.55; }
    .api-ai-summary-card .ai-summary-content p,
    .api-ai-summary-card .ai-summary-content ul,
    .api-ai-summary-card .ai-summary-content ol { margin-bottom: 8px; }
    .metadata { color: #6b7280; font-size: 0.95rem; margin-top: 6px; }
    .priority-reason { color: #374151; font-size: 0.95rem; margin-top: 6px; }
      .api-groups { display: grid; gap: 14px; }
      .api-group-title { display: flex; flex-direction: column; gap: 6px; align-items: flex-start; justify-content: flex-start; width: 100%; }
      .api-title-line { display: grid; grid-template-columns: auto minmax(0, 1fr); align-items: start; column-gap: 10px; width: 100%; text-align: left; }
      .api-meta-line { display: flex; gap: 10px; align-items: center; justify-content: space-between; width: 100%; }
      .api-count-badge { display: inline-flex; align-items: center; justify-content: center; margin-left: auto; padding: 6px 12px; border-radius: 999px; background: #e5e7eb; color: #374151; font-size: 0.92rem; font-weight: 700; white-space: nowrap; }
      .api-method-badge { display: inline-flex; align-items: center; justify-content: center; min-width: 58px; padding: 6px 12px; border-radius: 4px; color: #ffffff; font-size: 0.82rem; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; box-shadow: inset 0 0 0 1px rgba(255,255,255,0.16); }
      .api-method-badge.method-get { background: #61affe; }
      .api-method-badge.method-post { background: #49cc90; }
      .api-method-badge.method-put { background: #fca130; }
      .api-method-badge.method-patch { background: #50e3c2; color: #0f172a; box-shadow: inset 0 0 0 1px rgba(15,23,42,0.12); }
      .api-method-badge.method-delete { background: #f93e3e; }
      .api-method-badge.method-options { background: #0d5aa7; }
      .api-method-badge.method-head { background: #9012fe; }
      .api-method-badge.method-default { background: #6b7280; }
      .api-endpoint-text { display: block; flex: 1 1 auto; min-width: 0; font-weight: 700; color: #111827; word-break: break-all; text-align: left; justify-self: start; align-self: center; }
      .api-case-list { display: grid; gap: 12px; margin-top: 14px; }
      .api-case-accordion { border: 1px solid #e5e7eb; border-radius: 12px; background: #ffffff; overflow: hidden; }
      .api-case-accordion summary { list-style: none; cursor: pointer; padding: 14px; display: grid; grid-template-columns: minmax(0, 1fr) auto; column-gap: 12px; row-gap: 8px; align-items: start; background: #ffffff; text-align: left; }
      .api-case-accordion summary::-webkit-details-marker { display: none; }
      .api-case-accordion[open] summary { background: #f8fafc; }
      .api-case-body { padding: 0 14px 14px; }
      .api-case-card { border-top: 1px solid #e5e7eb; padding-top: 14px; background: #ffffff; }
      .api-case-header { display: flex; flex-wrap: wrap; justify-content: space-between; gap: 10px; align-items: center; margin-bottom: 10px; }
      .accordion-details summary > .api-group-title { min-width: 0; width: 100%; text-align: left; justify-self: start; align-self: start; }
      .api-case-accordion summary > div:first-child { min-width: 0; width: 100%; text-align: left; justify-self: start; align-self: start; }
      .api-case-accordion summary p.metadata { margin: 4px 0 0; text-align: left; }
      .api-case-meta { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; justify-content: flex-end; justify-self: end; }
      .api-kind-badge { display: inline-flex; align-items: center; justify-content: center; padding: 4px 10px; border-radius: 999px; font-size: 0.8rem; font-weight: 700; white-space: nowrap; }
      .api-role-badge { display: inline-flex; align-items: center; justify-content: center; padding: 4px 10px; border-radius: 999px; font-size: 0.8rem; font-weight: 700; white-space: nowrap; }
      .api-kind-read { background: #dbeafe; color: #1d4ed8; }
      .api-kind-validation { background: #fee2e2; color: #b91c1c; }
      .api-kind-auth { background: #ede9fe; color: #6d28d9; }
      .api-kind-integration { background: #fef3c7; color: #92400e; }
      .api-kind-trigger { background: #fde68a; color: #92400e; }
      .api-kind-smoke { background: #dcfce7; color: #166534; }
      .api-role-public { background: #e5e7eb; color: #374151; }
      .api-role-admin { background: #fee2e2; color: #b91c1c; }
      .api-role-lawyer { background: #dbeafe; color: #1d4ed8; }
      .api-role-company { background: #dcfce7; color: #166534; }
      .api-explainer-card { margin-top: 16px; }
      .api-explainer-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
      .api-explainer-column { min-width: 0; }
      .api-explainer-box { background: #ffffff; border: 1px solid #e5e7eb; border-radius: 14px; padding: 14px 16px; box-shadow: 0 8px 18px rgba(15, 23, 42, 0.04); }
      .api-explainer-column h4 { margin: 0 0 10px; font-size: 0.95rem; color: #111827; }
      .api-explainer-lines { display: grid; gap: 10px; }
      .api-explainer-line { margin: 0; line-height: 1.7; color: #374151; }
      @media (max-width: 900px) {
        .api-explainer-grid { grid-template-columns: 1fr; }
      }
      .accordion-details summary .api-group-title { display: flex !important; }
      .accordion-details summary .api-title-line { display: grid !important; }
      .accordion-details summary .api-endpoint-text { display: block !important; }
      .accordion-details summary .api-group-title .metadata { display: block !important; width: 100%; text-align: left !important; margin-left: 0 !important; }
    .api-case-accordion summary .metadata { display: block !important; text-align: left !important; }
    .skipped-flat-card { background: #ffffff; }
    .skipped-flat-summary { padding: 14px 16px; display: grid; grid-template-columns: minmax(0, 1fr) auto; column-gap: 12px; row-gap: 8px; align-items: start; background: #f8fafc; }
    .skipped-flat-summary > div:first-child { min-width: 0; }
    .skipped-flat-summary .metadata { margin: 4px 0 0; text-align: left; }
    .api-detail-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 12px; margin-top: 12px; }
    .api-detail-card { background: #f8fafc; border: 1px solid #e5e7eb; border-radius: 12px; padding: 12px; }
    .api-detail-card h4 { margin: 0 0 8px; font-size: 0.95rem; }
    .api-detail-card .code-block { margin-top: 0; }
  </style>
</head>
<body>
  <div class="page-header">
    <h1>Dev Analyzer Inspector 분석 리포트</h1>
    <p>
      {% if data.show_api_tab and not data.show_static_tab %}
      자동 생성된 API 테스트 결과를 개발자에게 보기 쉽게 정리합니다.
      {% elif data.show_static_tab and not data.show_api_tab %}
      자동 생성된 정적 분석 결과를 개발자에게 보기 쉽게 정리합니다.
      {% else %}
      자동 생성된 분석 결과를 개발자에게 보기 쉽게 정리합니다.
      {% endif %}
    </p>
  </div>

  {% if data.show_static_tab or data.show_api_tab %}
  <div class="tabs">
    {% if data.show_static_tab %}
    <button class="tab-button active" data-tab="static-analysis">정적 분석</button>
    {% endif %}
    {% if data.show_api_tab %}
    <button class="tab-button" data-tab="api-tests">API 테스트</button>
    {% endif %}
  </div>

  {% if data.show_static_tab %}
  <div id="static-analysis" class="tab-panel active">

  <div class="grid overview-grid">
    <div class="card">
      <h2>총 이슈</h2>
      <p class="stat">{{ data.summary.total }}</p>
      <p class="stat-label">전체 이슈 수</p>
    </div>
    <div class="card">
      <h2>심각도 분포</h2>
      <p class="badge badge-high">{{ data.summary.severity_labels.HIGH }} {{ data.summary.severity.HIGH }}</p>
      <p class="badge badge-medium">{{ data.summary.severity_labels.MEDIUM }} {{ data.summary.severity.MEDIUM }}</p>
      <p class="badge badge-low">{{ data.summary.severity_labels.LOW }} {{ data.summary.severity.LOW }}</p>
    </div>
    <div class="card">
      <h2>도구별 분포</h2>
      <ul class="summary-list">
        {% for tool, count in data.summary.tool.items() %}
        <li>{{ data.summary.tool_labels.get(tool, tool) }}: {{ count }}</li>
        {% endfor %}
      </ul>
    </div>
    <div class="card">
      <h2>가장 위험한 이슈</h2>
      {% if data.summary.top_risky_issue %}
      <p><strong>{{ data.summary.top_risky_issue.rule_id }}</strong></p>
      <p class="metadata">{{ data.summary.top_risky_issue.file }}:{{ data.summary.top_risky_issue.line }} ({{ data.summary.top_risky_issue.severity_label }}, {{ data.summary.top_risky_issue.tool_label }})</p>
      <p>{{ data.summary.top_risky_issue.translated_message }}</p>
      {% else %}
      <p>분석 결과가 없습니다.</p>
      {% endif %}
    </div>
  </div>

  {% if data.summary.most_affected_file %}
  <div class="grid" style="margin-top: 24px;">
    <div class="card">
      <h2>가장 많은 이슈가 발생한 파일</h2>
      <p><strong>{{ data.summary.most_affected_file.file }}</strong></p>
      <p class="metadata">{{ data.summary.most_affected_file.count }}건</p>
    </div>
    {% if data.summary.duplicate_rules %}
    <div class="card">
      <h2>중복 이슈 패턴</h2>
      <ul class="summary-list">
        {% for duplicate in data.summary.duplicate_rules %}
        <li>{{ duplicate.rule_id }}: {{ duplicate.count }}건</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}
  </div>
  {% endif %}

  <h2 class="section-title">이슈 그룹 요약</h2>
  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th>규칙</th>
          <th class="col-severity">심각도</th>
          <th class="col-count">건수</th>
          <th class="col-affected-files">영향 파일 수</th>
          <th class="col-tool">도구</th>
          <th>대표 메시지</th>
        </tr>
      </thead>
      <tbody>
        {% for group in data.rule_groups %}
        <tr>
          <td>{{ group.rule_id }}</td>
          <td class="severity-{{ group.severity }}">{{ group.severity_label }}</td>
          <td class="col-count">{{ group.count }}</td>
          <td class="col-affected-files">{{ group.affected_files }}</td>
          <td>{{ group.tool_labels | join(', ') }}</td>
          <td>{{ group.translated_message }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <h2 class="section-title">권장 수정 우선순위</h2>
  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th>우선순위</th>
          <th>규칙</th>
          <th>분류</th>
          <th class="col-severity">심각도</th>
          <th>영향 파일 수</th>
          <th>건수</th>
          <th>우선 수정 이유</th>
        </tr>
      </thead>
      <tbody>
        {% for item in data.recommendations %}
        <tr>
          <td>{{ item.rank }}</td>
          <td>{{ item.rule_id }}</td>
          <td>{{ item.category_label }}</td>
          <td class="severity-{{ item.severity }}">{{ item.severity_label }}</td>
          <td>{{ item.affected_files }}</td>
          <td>{{ item.count }}</td>
          <td class="priority-reason">{{ item.reason }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  <h2 class="section-title">주요 이슈</h2>
  <div class="card">
    <table class="table">
      <thead>
        <tr>
          <th class="col-index">#</th>
          <th class="col-tool">도구</th>
          <th class="col-severity">심각도</th>
          <th>규칙</th>
          <th>파일</th>
          <th class="col-line">줄</th>
          <th>메시지</th>
        </tr>
      </thead>
      <tbody>
        {% for item in data.issues %}
        <tr>
          <td class="col-index">{{ loop.index }}</td>
          <td>{{ item.tool_label }}</td>
          <td class="severity-{{ item.severity }}">{{ item.severity_label }}</td>
          <td>{{ item.rule_id }}</td>
          <td>{{ item.file }}</td>
          <td class="col-line">{{ item.line }}</td>
          <td>{{ item.translated_message }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>

  {% if data.ai_summary_html %}
  <h2 class="section-title">AI 요약</h2>
  <div class="card ai-summary-card">
    <div class="ai-summary-content">{{ data.ai_summary_html | safe }}</div>
  </div>
  {% endif %}

  <h2 class="section-title">이슈 코드 샘플</h2>
  {% for item in data.static_issues %}
  <div class="card">
    <h3>{{ loop.index }}. {{ item.file }}:{{ item.line }} ({{ item.tool_label }})</h3>
    <p class="metadata">{{ item.rule_id }}</p>
    <details class="accordion-details">
      <summary><span>코드 샘플 및 수정 제안 열기</span><strong>▼</strong></summary>
      <div class="accordion-content">
        {% if item.fix_suggestion %}
        <div class="fix-suggestion">
          <h4>수정 제안: {{ item.fix_suggestion.title }}</h4>
          <p><strong>위험한 이유:</strong> {{ item.fix_suggestion.why_risky }}</p>
          <p><strong>권장 수정 방법:</strong> {{ item.fix_suggestion.recommended_fix }}</p>
          <div class="fix-suggestion-code">
            <p><strong>수정 전 예시</strong></p>
            <div class="code-block">{{ item.code or item.fix_suggestion.before_example or "코드 정보 없음" }}</div>
          </div>
          <div class="fix-suggestion-code">
            <p><strong>수정 후 예시</strong></p>
            <div class="code-block">{{ item.fix_suggestion.after_example }}</div>
          </div>
        </div>
        {% endif %}
      </div>
    </details>
  </div>
  {% endfor %}
  </div>
  {% endif %}

  {% if data.show_api_tab %}
  <div id="api-tests" class="tab-panel">
    <div class="grid overview-grid">
        <div class="card">
          <h2>Total Endpoints</h2>
          <p class="stat">{{ data.api_tab.endpoint_coverage.discovered_total }}</p>
          <p class="stat-label">Discovered API endpoints in this project</p>
        </div>
        <div class="card">
          <h2>Endpoint Coverage</h2>
          <p class="stat">{{ data.api_tab.endpoint_coverage.covered_total }} / {{ data.api_tab.endpoint_coverage.discovered_total }}</p>
          <p class="stat-label">Unique covered endpoints / {{ data.api_tab.endpoint_coverage.coverage_rate }}%</p>
          <p class="metadata">This card uses unique endpoint count.</p>
        </div>
        <div class="card">
          <h2>Test Case Result</h2>
          <p class="badge badge-low badge-block">통과 {{ data.api_tab.layer_summary.passed.endpoint_count }} endpoints / {{ data.api_tab.layer_summary.passed.case_count }} cases</p>
          <p class="badge badge-high badge-block">실패 {{ data.api_tab.layer_summary.failed.endpoint_count }} endpoints / {{ data.api_tab.layer_summary.failed.case_count }} cases</p>
          <p class="badge badge-medium badge-block">건너뜀 {{ data.api_tab.layer_summary.skipped.endpoint_count }} endpoints / {{ data.api_tab.layer_summary.skipped.case_count }} cases</p>
          <p class="stat-label">실행된 테스트 케이스 {{ data.api_tab.summary.executed }} / 전체 테스트 케이스 {{ data.api_tab.summary.total }} / 통과율 {{ data.api_tab.summary.pass_rate }}%</p>
          {% if data.api_tab.failure_summary and data.api_tab.failure_summary.top %}
          <p class="metadata">대표 실패 유형: {{ data.api_tab.failure_summary.top.label }} ({{ data.api_tab.failure_summary.top.case_count }} cases / {{ data.api_tab.failure_summary.top.endpoint_count }} endpoints)</p>
          {% endif %}
        </div>
    </div>

    <div class="grid overview-grid" style="margin-top: 16px;">
        <div class="card">
          <h2>Failure Analysis</h2>
          {% if data.api_tab.failure_summary and data.api_tab.failure_summary.types %}
            {% for item in data.api_tab.failure_summary.types %}
            <p class="badge badge-{{ item.class }}">{{ item.label }} {{ item.endpoint_count }} endpoints / {{ item.case_count }} cases</p>
            {% endfor %}
          {% else %}
          <p class="stat-label">이번 실행에서 실패한 API 테스트 케이스가 없습니다.</p>
          {% endif %}
        </div>
        <div class="card api-ai-summary-card">
          <h2>AI Test Summary</h2>
          <div class="ai-summary-content">{{ data.api_ai_summary_html | safe }}</div>
        </div>
    </div>

    {% if data.api_tab.collection_generation and data.api_tab.collection_generation.mode %}
    <div class="card" style="margin-top: 16px;">
      <h2>Auto Test Design</h2>
      <p class="metadata">
        Mode: {{ data.api_tab.collection_generation.mode }}
        {% if data.api_tab.collection_generation.source %}/ Source: {{ data.api_tab.collection_generation.source }}{% endif %}
        {% if data.api_tab.collection_generation.reused %}/ Reused existing design{% else %}/ Freshly generated{% endif %}
        {% if data.api_tab.collection_generation.llm_enabled %}/ LLM inference enabled{% else %}/ Fallback mode{% endif %}
      </p>
      <p class="metadata">
        Public routes {{ data.api_tab.collection_generation.public_routes or 0 }} /
        Protected routes {{ data.api_tab.collection_generation.protected_routes or 0 }} /
        Skipped routes {{ data.api_tab.collection_generation.skipped_routes or 0 }}
      </p>
      {% if data.api_tab.collection_generation.blueprint_path %}
      <p class="metadata">Blueprint: {{ data.api_tab.collection_generation.blueprint_path }}</p>
      {% endif %}
      {% if data.api_tab.collection_generation.collection_path %}
      <p class="metadata">Collection: {{ data.api_tab.collection_generation.collection_path }}</p>
      {% endif %}
    </div>
    {% endif %}

    <div class="card api-explainer-card">
      <div class="api-explainer-lines">
        <p class="api-explainer-line">
          <span class="badge badge-low">Passed Cases</span>
          예상한 응답이나 오류 패턴이 확인된 테스트입니다. 조회 성공뿐 아니라 의도한 검증 오류, 인증 오류 시나리오도 포함됩니다.
        </p>
        <p class="api-explainer-line">
          <span class="badge badge-high">Failed Cases</span>
          기대한 상태 코드, 응답 구조, 오류 패턴과 실제 결과가 달랐던 테스트입니다. 회귀나 계약 불일치 가능성을 먼저 확인하면 좋습니다.
        </p>
        <p class="api-explainer-line">
          <span class="badge badge-medium">Skipped Cases</span>
          콜백, 웹훅, 외부 연동, 트리거성 동작처럼 기본 smoke에서 재현하기 어렵거나 부작용 가능성이 있어 별도 integration 검증이 필요한 테스트입니다.
        </p>
      </div>
    </div>

    <h2 class="section-title">API Test Results</h2>
    <div class="card">
      {% if data.api_tab.available and data.api_tab.groups %}
      {% set layer_specs = [
        ('api-passed', 'Passed', data.api_tab.group_layers.passed, data.api_tab.layer_summary.passed),
        ('api-failed', 'Failed', data.api_tab.group_layers.failed, data.api_tab.layer_summary.failed),
        ('api-skipped', 'Skipped', data.api_tab.group_layers.skipped, data.api_tab.layer_summary.skipped)
      ] %}
      <div class="subtabs">
        {% for layer_id, layer_label, layer_groups, layer_summary in layer_specs %}
        <button class="subtab-button subtab-{{ layer_id.replace('api-', '') }}{% if loop.first %} active{% endif %}" data-subtab="{{ layer_id }}">{{ layer_label }} {{ layer_summary.endpoint_count }} endpoints / {{ layer_summary.case_count }} cases</button>
        {% endfor %}
      </div>
      {% for layer_id, layer_label, layer_groups, layer_summary in layer_specs %}
      <div id="{{ layer_id }}" class="subtab-panel{% if loop.first %} active{% endif %}">
        {% if layer_id == 'api-passed' %}
          <div class="api-explainer-grid" style="margin-bottom: 16px;">
            <div class="api-explainer-column api-explainer-box">
              <h4>테스트 유형</h4>
              <div class="api-explainer-lines">
                <p class="api-explainer-line">
                  <span class="api-kind-badge api-kind-read">조회</span>
                  목록, 상세, 검색처럼 정상 응답 구조를 확인하는 읽기 중심 테스트입니다.
                </p>
                <p class="api-explainer-line">
                  <span class="api-kind-badge api-kind-validation">검증 오류</span>
                  빈 값이나 잘못된 입력에 대해 API가 400 계열 검증 오류로 올바르게 거절하는지 확인합니다.
                </p>
                <p class="api-explainer-line">
                  <span class="api-kind-badge api-kind-auth">인증 오류</span>
                  토큰 누락이나 잘못된 인증 정보 상황에서 인증 관련 오류 응답이 정상적으로 반환되는지 확인합니다.
                </p>
                <p class="api-explainer-line">
                  <span class="api-kind-badge api-kind-smoke">헬스체크 / 스모크</span>
                  서버 기동, 문서 노출, 기본 엔드포인트 연결 상태를 빠르게 확인하는 기초 테스트입니다.
                </p>
              </div>
            </div>
            <div class="api-explainer-column api-explainer-box">
              <h4>권한 유형</h4>
              <div class="api-explainer-lines">
                <p class="api-explainer-line">
                  <span class="api-role-badge api-role-public">Public</span>
                  토큰 없이 호출 가능한 공개 API를 검증한 케이스입니다.
                </p>
                <p class="api-explainer-line">
                  <span class="api-role-badge api-role-admin">Admin</span>
                  관리자 권한 토큰으로 호출해 관리자 전용 API 또는 관리자 조회 권한을 검증한 케이스입니다.
                </p>
                <p class="api-explainer-line">
                  <span class="api-role-badge api-role-lawyer">Lawyer</span>
                  변호사 권한 토큰으로 호출해 변호사 사용자 관점의 접근 가능 여부를 검증한 케이스입니다.
                </p>
                <p class="api-explainer-line">
                  <span class="api-role-badge api-role-company">Company Manager</span>
                  기업 담당자 권한 토큰으로 호출해 기업 사용자 관점의 접근 가능 여부를 검증한 케이스입니다.
                </p>
              </div>
            </div>
          </div>
        {% endif %}
        {% if layer_id == 'api-skipped' %}
          <div class="api-explainer-grid" style="margin-bottom: 16px;">
            <div class="api-explainer-column api-explainer-box">
              <h4>테스트 유형</h4>
              <div class="api-explainer-lines">
                <p class="api-explainer-line">
                  <span class="api-kind-badge api-kind-integration">콜백/연동</span>
                  외부 서비스의 실제 콜백, 서명, 공급자 응답, 웹훅 payload가 있어야 정확히 검증할 수 있는 유형입니다.
                </p>
                <p class="api-explainer-line">
                  <span class="api-kind-badge api-kind-trigger">트리거/배치</span>
                  실행 시 데이터 갱신, 집계, 동기화 같은 부작용이 있어 기본 smoke에서 제외한 유형입니다.
                </p>
                <p class="api-explainer-line">
                  <span class="api-kind-badge api-kind-integration">연동 제외</span>
                  공개 라우트이지만 기본 smoke 범위를 넘어서는 외부 의존성이나 운영 영향이 있어 별도 검증이 필요한 유형입니다.
                </p>
              </div>
            </div>
            <div class="api-explainer-column api-explainer-box">
              <h4>권한 유형</h4>
              <div class="api-explainer-lines">
                <p class="api-explainer-line">
                  <span class="api-role-badge api-role-public">Public</span>
                  대부분 토큰 없이 접근 가능하지만 외부 연동 조건이 부족해 기본 실행에서 건너뛴 케이스입니다.
                </p>
                <p class="api-explainer-line">
                  <span class="api-role-badge api-role-admin">Admin</span>
                  관리자 권한이 있어도 외부 콜백, 파일, 배치 조건이 필요해 별도 시나리오가 필요한 케이스입니다.
                </p>
                <p class="api-explainer-line">
                  <span class="api-role-badge api-role-lawyer">Lawyer</span>
                  변호사 권한으로 접근할 수 있어도 외부 데이터나 상태 조건이 있어 기본 smoke에서는 제외한 케이스입니다.
                </p>
                <p class="api-explainer-line">
                  <span class="api-role-badge api-role-company">Company Manager</span>
                  기업 담당자 권한과 별개로 외부 연동 또는 부작용 조건이 있어 분리된 케이스입니다.
                </p>
              </div>
            </div>
          </div>
        {% endif %}
        {% if layer_groups %}
        {% if layer_id == 'api-skipped' %}
        <div class="api-groups">
          {% for group in layer_groups %}
            {% for test in group.cases %}
            <div class="accordion-details skipped-flat-card">
              <div class="skipped-flat-summary">
                <div>
                  <p class="metadata">
                    <span class="api-title-line">
                      <span class="api-method-badge method-{{ (test.method or 'default') | lower }}">{{ test.method or '-' }}</span>
                      <span class="api-endpoint-text">{{ test.request_target }}</span>
                    </span>
                  </p>
                  {% if test.kind and test.kind.label %}
                  <p class="metadata">
                    {% if test.kind and test.kind.label %}<span class="api-kind-badge api-kind-{{ test.kind.class }}">{{ test.kind.label }}</span>{% endif %}
                    {% if test.role and test.role.label %}<span class="api-role-badge api-role-{{ test.role.class }}">{{ test.role.label }}</span>{% endif %}
                  </p>
                  {% endif %}
                  <p class="metadata"><strong>이유:</strong> {{ test.translated_reason or test.message }}</p>
                </div>
                <div class="api-case-meta">
                  <span class="badge badge-{{ test.result_class }}">{{ test.result_label }}</span>
                </div>
              </div>
            </div>
            {% endfor %}
          {% endfor %}
        </div>
        {% else %}
        <div class="api-groups">
          {% for group in layer_groups %}
          <details class="accordion-details">
            <summary>
              <span class="api-group-title">
                <span class="api-title-line">
                  <span class="api-method-badge method-{{ (group.method or 'default') | lower }}">{{ group.method or '-' }}</span>
                  <span class="api-endpoint-text">{{ group.endpoint or '-' }}</span>
                </span>
                <span class="api-meta-line">
                  <span class="metadata">{{ group.name }}</span>
                  <span class="api-count-badge">Cases {{ group.total }}</span>
                </span>
              </span>
            </summary>
            <div class="accordion-content">
              <div class="api-case-list">
                {% for test in group.cases %}
                <details class="api-case-accordion">
                  <summary>
                    <div>
                      <strong>{{ test.name }}</strong>
                      <p class="metadata">
                        <span class="api-title-line">
                          <span class="api-method-badge method-{{ (test.method or 'default') | lower }}">{{ test.method or '-' }}</span>
                          <span class="api-endpoint-text">{{ test.request_target }}</span>
                        </span>
                      </p>
                      {% if test.kind and test.kind.label %}
                      <p class="metadata">
                        {% if test.kind and test.kind.label %}<span class="api-kind-badge api-kind-{{ test.kind.class }}">{{ test.kind.label }}</span>{% endif %}
                        {% if test.role and test.role.label %}<span class="api-role-badge api-role-{{ test.role.class }}">{{ test.role.label }}</span>{% endif %}
                        {% if test.failure_type and test.failure_type.label %}<span class="badge badge-{{ test.failure_type.class }}">{{ test.failure_type.label }}</span>{% endif %}
                      </p>
                      {% endif %}
                      {% if test.result == 'SKIPPED' and test.translated_reason %}
                      <p class="metadata"><strong>이유:</strong> {{ test.translated_reason }}</p>
                      {% endif %}
                    </div>
                    <div class="api-case-meta">
                      <span class="badge badge-{{ test.result_class }}">{{ test.result_label }}</span>
                      <span class="metadata">Status {{ test.status_code }}</span>
                      <span class="metadata">Time {{ test.response_time_ms }}ms</span>
                    </div>
                  </summary>
                  <div class="api-case-body">
                    <div class="api-case-card">
                        <h4>이유</h4>
                      {% if test.result in ['FAILED', 'SKIPPED'] and test.translated_reason %}
                      <div class="fix-suggestion" style="margin-top: 12px;">
                        <h4>이유</h4>
                        <p>{{ test.translated_reason }}</p>
                      </div>
                      {% endif %}
                      <div class="api-detail-grid">
                        <div class="api-detail-card">
                          <h4>Request</h4>
                          <p class="metadata">Target: {{ test.request_target }}</p>
                          <p class="metadata">Headers</p>
                          <div class="code-block">{{ test.request_headers }}</div>
                          <p class="metadata">Body</p>
                          <div class="code-block">{{ test.request_body }}</div>
                        </div>
                        <div class="api-detail-card">
                          <h4>Response</h4>
                          <p class="metadata">Status code: {{ test.status_code }} / Response time: {{ test.response_time_ms }}ms</p>
                          <p class="metadata">Headers</p>
                          <div class="code-block">{{ test.response_headers }}</div>
                          <p class="metadata">Body</p>
                          <div class="code-block">{{ test.response_body }}</div>
                        </div>
                      </div>
                    </div>
                  </div>
                </details>
                {% endfor %}
              </div>
            </div>
          </details>
          {% endfor %}
        </div>
        {% endif %}
        {% else %}
        <div class="card">
          <p>No APIs in the {{ layer_label }} layer.</p>
        </div>
        {% endif %}
      </div>
      {% endfor %}
      {% else %}
      <p>No API test results available.</p>
      {% if data.api_test_status.reason %}
      <p class="metadata">{{ data.api_test_status.reason }}</p>
      {% else %}
      <p class="metadata">Check `.dev-analyzer.yml` and the Newman execution result.</p>
      {% endif %}
      {% endif %}
    </div>
    </div>

    {% if data.api_test_issues %}
    <h2 class="section-title">Failed API Details</h2>
    <div class="card">
      <table class="table">
        <thead>
          <tr>
            <th>Test</th>
            <th>Method</th>
            <th>Endpoint</th>
            <th class="col-severity">Severity</th>
            <th>Status Code</th>
            <th>Response Time (ms)</th>
            <th>Message</th>
          </tr>
        </thead>
        <tbody>
          {% for item in data.api_test_issues %}
          <tr>
            <td>{{ item.rule_id }}</td>
            <td>{{ item.method or "-" }}</td>
            <td>{{ item.endpoint or "-" }}</td>
            <td class="severity-{{ item.severity }}">{{ item.severity_label }}</td>
            <td>{{ item.status_code or "-" }}</td>
            <td>{{ item.response_time_ms or "-" }}</td>
            <td>{{ item.translated_message }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% if data.api_test_summary.slowest %}
      <p class="metadata" style="margin-top: 16px;">
        Slowest failed response: {{ data.api_test_summary.slowest.method or "-" }} {{ data.api_test_summary.slowest.endpoint or "-" }}
        ({{ data.api_test_summary.slowest.response_time_ms or "-" }}ms)
      </p>
      {% endif %}
    </div>
    {% endif %}
  </div>
  {% endif %}
  {% endif %}

  <script>
    const showStaticTab = {{ 'true' if data.show_static_tab else 'false' }};
    const showApiTab = {{ 'true' if data.show_api_tab else 'false' }};
    const defaultTab = {{ data.default_tab | tojson }};
    const tabButtons = document.querySelectorAll('.tab-button');
    const tabPanels = document.querySelectorAll('.tab-panel');

    if (!showStaticTab) {
      document.querySelector('[data-tab="static-analysis"]')?.remove();
      document.getElementById('static-analysis')?.remove();
    }

    if (!showApiTab) {
      document.querySelector('[data-tab="api-tests"]')?.remove();
      document.getElementById('api-tests')?.remove();
    }

    const visibleButtons = document.querySelectorAll('.tab-button');
    const visiblePanels = document.querySelectorAll('.tab-panel');
    const tabsContainer = document.querySelector('.tabs');

    if (tabsContainer && visibleButtons.length <= 1) {
      tabsContainer.style.display = 'none';
    }

    visibleButtons.forEach((button) => {
      button.classList.toggle('active', button.dataset.tab === defaultTab);
    });
    visiblePanels.forEach((panel) => {
      panel.classList.toggle('active', panel.id === defaultTab);
    });

    visibleButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const target = button.dataset.tab;
        visibleButtons.forEach((item) => item.classList.toggle('active', item === button));
        visiblePanels.forEach((panel) => panel.classList.toggle('active', panel.id === target));
      });
    });

    const subtabButtons = document.querySelectorAll('.subtab-button');
    const subtabPanels = document.querySelectorAll('.subtab-panel');
    subtabButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const target = button.dataset.subtab;
        subtabButtons.forEach((item) => item.classList.toggle('active', item === button));
        subtabPanels.forEach((panel) => panel.classList.toggle('active', panel.id === target));
      });
    });
  </script>
</body>
</html>
